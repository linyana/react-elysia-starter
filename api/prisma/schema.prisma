generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
}

model projects {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  path        String   @unique
  description String   @default("")
  color       String   @default("#5F7BD8")
}
