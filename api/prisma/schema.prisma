generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgres"
}

model projects {
  id          Int      @id @default(autoincrement())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  name        String
  path        String   @unique
  description String   @default("")
  color       String   @default("#5F7BD8")
}

model tenants {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  name      String?
  users     users[]
}

model users {
  id        Int      @id @default(autoincrement())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  email     String   @unique
  password  String
  name      String
  tenantId  Int
  tenant    tenants  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}
