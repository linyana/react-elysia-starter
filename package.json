{
	"name": "project-name",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"app",
		"api"
	],
	"scripts": {
		"dev": "bun scripts/dev.ts",
		"setup": "bun scripts/setup.ts",
		"build": "vp run -r build",
		"type-check": "vp run -r type-check",
		"check": "vp check scripts app api",
		"check:fix": "vp check --fix app scripts api",
		"build:app": "vp run -F @project-name/app build",
		"build:api": "vp run -F @project-name/api build",
		"prisma:push": "vp run -F @project-name/api prisma:push",
		"prisma:generate": "vp run -F @project-name/api prisma:generate",
		"prisma:seed": "vp run -F @project-name/api prisma:seed"
	},
	"devDependencies": {
		"@types/node": "^25.8.0",
		"@typescript/native-preview": "^7.0.0-dev.20260518.1",
		"@voidzero-dev/vite-plus-core": "^0.1.21",
		"vite-plus": "^0.1.21"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "bun@1.3.11",
	"dependencies": {
		"dotenv": "^17.4.2"
	}
}
