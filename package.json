{
	"name": "project-name",
	"version": "1.0.0",
	"private": true,
	"type": "module",
	"workspaces": [
		"app",
		"api"
	],
	"scripts": {
		"dev": "bun scripts/dev.ts",
		"dev:vp": "vp run -r dev",
		"build": "vp run -r build",
		"build:app": "vp run -F @project-name/app build",
		"build:api": "vp run -F @project-name/api build",
		"prisma:push": "vp run -F @project-name/api prisma:push",
		"prisma:generate": "vp run -F @project-name/api prisma:generate",
		"prisma:seed": "vp run -F @project-name/api prisma:seed",
		"type-check": "vp run -r type-check",
		"lint": "vp lint",
		"format": "vp fmt",
		"format:check": "vp fmt --check",
		"check": "vp check",
		"setup": "bun scripts/setup-agents.ts",
		"postinstall": "bun scripts/setup-agents.ts"
	},
	"devDependencies": {
		"@types/node": "^25.5.0",
		"@typescript/native-preview": "^7.0.0-dev.20260425.1",
		"@voidzero-dev/vite-plus-core": "^0.1.20",
		"vite-plus": "^0.1.20"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"packageManager": "bun@1.3.11",
	"dependencies": {
		"dotenv": "^17.4.0"
	}
}
